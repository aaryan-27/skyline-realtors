# ─────────────────────────────────────────────────────────────
# DLF Privana Amraj Infra — Environment Variables
# Copy to .env.local and fill in real values
# ─────────────────────────────────────────────────────────────

# Site
NEXT_PUBLIC_SITE_URL=https://www.amrajinfra.in

# Supabase (Lead storage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp Cloud API (lead notification to business)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_NUMBER=919310203019

# Email notifications (Resend / SMTP)
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=leads@mahadevproperties.in

# Google Sheets integration (Apps Script Web App URL or service account webhook)
GOOGLE_SHEETS_WEBHOOK_URL=

# Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=
